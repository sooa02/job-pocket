# frontend env
API_BASE_URL=

# backend env
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)

OPENAI_API_KEY=
RUNPOD_API_KEY=
GROQ_API_KEY=

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
