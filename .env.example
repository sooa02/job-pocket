MYSQL_RDB_PASSWORD=rdb_password

# Vector DB
VECTOR_DB_URL=mysql+pymysql://vector_user:vector_password@database:3306/job_pocket_vector
MYSQL_VECTOR_USER=vector_user
MYSQL_VECTOR_PASSWORD=vector_password

# database env
MYSQL_ROOT_PASSWORD=root
TIMEZONE=Asia/Seoul
